{
  "//": "eToro Synapse -> Databricks BladeBridge custom config (dual-schema, single catalog).",
  "//_purpose": "Routes the transpiler output across two UC targets, both inside the dwh_daily_process catalog: DWH_staging reads become dwh_daily_process.daily_snapshot.<table> (read-only snapshot of the production source data), and every other Synapse schema becomes dwh_daily_process.migration_tables.<table> (the writable target for migrated SP outputs). Also strips LOCATION clauses so generated tables stay managed in UC and can never overwrite an existing data-lake path.",
  "//_history": [
    "v1 (2026-04-29): single quarantine schema main.de_output_synapse_migration.",
    "v2 (2026-05-11): split into dwh_daily_process.daily_snapshot (read) + migration_output.migration_tables (write).",
    "v3 (2026-05-11): collapsed to one catalog -- dwh_daily_process.daily_snapshot (read) + dwh_daily_process.migration_tables (write). The migration_output catalog was never created; the actual schemas live side-by-side under dwh_daily_process."
  ],
  "//_install": "databricks labs lakebridge install-transpile  ->  override existing  ->  paste the absolute path to this file when prompted.",
  "//_post_process_alternative": "If you do not want to re-run the transpiler from scratch, the equivalent rewriter is at tools/lakebridge/rewrite_to_dual_target.py -- it applies the same mappings to the already-transpiled output.",
  "//_uc_prereqs": [
    "CREATE CATALOG IF NOT EXISTS dwh_daily_process;",
    "CREATE SCHEMA IF NOT EXISTS dwh_daily_process.daily_snapshot;",
    "CREATE SCHEMA IF NOT EXISTS dwh_daily_process.migration_tables;"
  ],
  "//_inherit_path_note": "The inherit_from path below is for Windows install of lakebridge with Python 3.10. Adjust if your venv differs.",

  "inherit_from": [
    "C:/Users/guyman/.databricks/labs/remorph-transpilers/bladebridge/lib/.venv/lib/python3.10/site-packages/databricks/labs/bladebridge/Converter/Configs/base_synapse2databricks_sql.json"
  ],

  "target_sql_file_header": "USE CATALOG dwh_daily_process;\nUSE SCHEMA migration_tables;\n",

  "line_subst": [
    { "//": "--- DWH_staging is the daily-snapshot READ source: route to dwh_daily_process.daily_snapshot. ---" },
    { "from": "\\bDWH_staging\\b\\.",               "to": "dwh_daily_process.daily_snapshot." },

    { "//": "--- Every other Synapse schema is a WRITE target: route to dwh_daily_process.migration_tables. ---",
      "//_order": "Order matters: BladeBridge applies rules in array order; longer/more-specific schemas first." },

    { "from": "\\bBI_DB_Migration\\b\\.",          "to": "dwh_daily_process.migration_tables." },
    { "from": "\\bBI_DB_mixpanel\\b\\.",            "to": "dwh_daily_process.migration_tables." },
    { "from": "\\bBI_DB_python\\b\\.",              "to": "dwh_daily_process.migration_tables." },
    { "from": "\\bBI_DB_staging\\b\\.",             "to": "dwh_daily_process.migration_tables." },
    { "from": "\\bBI_DB_dbo\\b\\.",                 "to": "dwh_daily_process.migration_tables." },

    { "from": "\\bCopyFromLake_staging\\b\\.",      "to": "dwh_daily_process.migration_tables." },
    { "from": "\\bCopyFromLake\\b\\.",              "to": "dwh_daily_process.migration_tables." },

    { "from": "\\bDealing_staging\\b\\.",           "to": "dwh_daily_process.migration_tables." },
    { "from": "\\bDealing_dbo\\b\\.",               "to": "dwh_daily_process.migration_tables." },

    { "from": "\\bDWH_Migration\\b\\.",             "to": "dwh_daily_process.migration_tables." },
    { "from": "\\bDWH_pagetracking\\b\\.",          "to": "dwh_daily_process.migration_tables." },
    { "from": "\\bDWH_tracking\\b\\.",              "to": "dwh_daily_process.migration_tables." },
    { "from": "\\bDWH_watchlists\\b\\.",            "to": "dwh_daily_process.migration_tables." },
    { "from": "\\bDWH_dbo\\b\\.",                   "to": "dwh_daily_process.migration_tables." },

    { "from": "\\bDE_dbo\\b\\.",                    "to": "dwh_daily_process.migration_tables." },

    { "from": "\\beMoney_Dictionary_tmp\\b\\.",     "to": "dwh_daily_process.migration_tables." },
    { "from": "\\beMoney_Dictionary\\b\\.",         "to": "dwh_daily_process.migration_tables." },
    { "from": "\\beMoney_Tribe_tmp\\b\\.",          "to": "dwh_daily_process.migration_tables." },
    { "from": "\\beMoney_Tribe\\b\\.",              "to": "dwh_daily_process.migration_tables." },
    { "from": "\\beMoney_dbo_tmp\\b\\.",            "to": "dwh_daily_process.migration_tables." },
    { "from": "\\beMoney_dbo\\b\\.",                "to": "dwh_daily_process.migration_tables." },
    { "from": "\\beMoney_google_sheets\\b\\.",      "to": "dwh_daily_process.migration_tables." },

    { "from": "\\bEXW_Currency_tmp\\b\\.",          "to": "dwh_daily_process.migration_tables." },
    { "from": "\\bEXW_Currency\\b\\.",              "to": "dwh_daily_process.migration_tables." },
    { "from": "\\bEXW_Dictionary_tmp\\b\\.",        "to": "dwh_daily_process.migration_tables." },
    { "from": "\\bEXW_Dictionary\\b\\.",            "to": "dwh_daily_process.migration_tables." },
    { "from": "\\bEXW_Settings_tmp\\b\\.",          "to": "dwh_daily_process.migration_tables." },
    { "from": "\\bEXW_Settings\\b\\.",              "to": "dwh_daily_process.migration_tables." },
    { "from": "\\bEXW_Staking_tmp\\b\\.",           "to": "dwh_daily_process.migration_tables." },
    { "from": "\\bEXW_Staking\\b\\.",               "to": "dwh_daily_process.migration_tables." },
    { "from": "\\bEXW_Wallet_tmp\\b\\.",            "to": "dwh_daily_process.migration_tables." },
    { "from": "\\bEXW_Wallet\\b\\.",                "to": "dwh_daily_process.migration_tables." },
    { "from": "\\bEXW_dbo\\b\\.",                   "to": "dwh_daily_process.migration_tables." },

    { "from": "\\bEXE_dbo\\b\\.",                   "to": "dwh_daily_process.migration_tables." },
    { "from": "\\bEXE\\b\\.",                       "to": "dwh_daily_process.migration_tables." },

    { "from": "\\bMoneyTransfe_Billing_tmp\\b\\.",  "to": "dwh_daily_process.migration_tables." },
    { "from": "\\bMoneyTransfe_Billing\\b\\.",      "to": "dwh_daily_process.migration_tables." },

    { "from": "\\bGCP_DataSet_BQ_Status\\b\\.",     "to": "dwh_daily_process.migration_tables." },
    { "from": "\\bGCP_DataSet_Copy_Discovery\\b\\.","to": "dwh_daily_process.migration_tables." },
    { "from": "\\bGCP_DataSet_Experiments\\b\\.",   "to": "dwh_daily_process.migration_tables." },
    { "from": "\\bGCP_DataSet_RecoSys\\b\\.",       "to": "dwh_daily_process.migration_tables." },

    { "from": "\\bFivetran_google_sheets\\b\\.",    "to": "dwh_daily_process.migration_tables." },
    { "from": "\\bML_General_DataSet\\b\\.",        "to": "dwh_daily_process.migration_tables." },
    { "from": "\\bSalesForce_dbo\\b\\.",            "to": "dwh_daily_process.migration_tables." },
    { "from": "\\bsalesforce\\b\\.",                "to": "dwh_daily_process.migration_tables." },
    { "from": "\\bProdData_dbo\\b\\.",              "to": "dwh_daily_process.migration_tables." },
    { "from": "\\bgeneral_tmp\\b\\.",               "to": "dwh_daily_process.migration_tables." },
    { "from": "\\bgeneral\\b\\.",                   "to": "dwh_daily_process.migration_tables." },
    { "from": "\\bSHA\\b\\.",                       "to": "dwh_daily_process.migration_tables." },
    { "from": "\\bQG\\b\\.",                        "to": "dwh_daily_process.migration_tables." },
    { "from": "\\bdbo\\b\\.",                       "to": "dwh_daily_process.migration_tables." },

    { "//": "--- Catalog/qualified-name redirects: any leftover [DB].[schema]. or [DB].dbo. land in the safe schema ---" },
    { "from": "\\bsql_dp_prod_we\\b\\.\\w+\\b\\.",  "to": "dwh_daily_process.migration_tables." },
    { "from": "\\bsql_dp_stage_we\\b\\.\\w+\\b\\.", "to": "dwh_daily_process.migration_tables." },

    { "//": "--- LOCATION-stripping safety net: prevent BladeBridge from binding a generated table to an existing lake path ---" },
    { "from": "(?i)\\bLOCATION\\s+'abfss:[^']*'",   "to": "" },
    { "from": "(?i)\\bLOCATION\\s+'dbfs:[^']*'",    "to": "" },
    { "from": "(?i)\\bLOCATION\\s+'s3:[^']*'",      "to": "" },
    { "from": "(?i)\\bLOCATION\\s+'wasb[s]?:[^']*'","to": "" },
    { "from": "(?i)\\bLOCATION\\s+\"abfss:[^\"]*\"","to": "" },
    { "from": "(?i)\\bLOCATION\\s+\"dbfs:[^\"]*\"", "to": "" },

    { "//": "--- Force EXTERNAL TABLE -> regular managed TABLE (no path needed) ---" },
    { "from": "(?i)\\bCREATE\\s+EXTERNAL\\s+TABLE\\b", "to": "CREATE TABLE" },
    { "from": "(?i)\\bCREATE\\s+OR\\s+REPLACE\\s+EXTERNAL\\s+TABLE\\b", "to": "CREATE OR REPLACE TABLE" }
  ],

  "block_subst": [
    { "//": "Strip Synapse-style WITH (LOCATION = ...) blocks if any survive line_subst" },
    { "from": "(?is)\\bWITH\\s*\\(\\s*LOCATION\\s*=[^)]*\\)", "to": "" }
  ]
}
