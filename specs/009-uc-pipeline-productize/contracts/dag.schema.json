{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://etoro/uc-pipeline-doc/dag.schema.json",
  "title": "UC Pipeline Lineage DAG",
  "description": "Persistent representation of the column-lineage DAG built once per uc-pipeline-doc run.",
  "type": "object",
  "required": ["built_at", "uc_query_budget", "pilot_schemas", "nodes", "edges"],
  "additionalProperties": false,
  "properties": {
    "built_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 UTC timestamp when Phase -1 issued the column_lineage query."
    },
    "uc_query_budget": {
      "type": "object",
      "required": ["column_lineage_queries", "table_lineage_queries", "information_schema_queries"],
      "additionalProperties": false,
      "properties": {
        "column_lineage_queries": { "type": "integer", "const": 1 },
        "table_lineage_queries": { "type": "integer", "const": 1 },
        "information_schema_queries": { "type": "integer", "minimum": 1, "maximum": 2 }
      },
      "description": "Hard ceiling per FR-005 / SC-005. Validator checks this on read; any value >1 for the column/table lineage budgets fails the run."
    },
    "pilot_schemas": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "uniqueItems": true,
      "description": "The five named pilot schemas. Recorded so re-reads from disk can validate scope without re-querying UC."
    },
    "nodes": {
      "type": "array",
      "items": { "$ref": "#/$defs/node" }
    },
    "edges": {
      "type": "array",
      "items": { "$ref": "#/$defs/edge" }
    }
  },
  "$defs": {
    "node": {
      "type": "object",
      "required": [
        "full_name",
        "catalog",
        "schema",
        "table_type",
        "wiki_status",
        "routing_rule",
        "cached_wiki_path",
        "in_pilot_scope",
        "topological_layer",
        "source_code_available",
        "column_count"
      ],
      "additionalProperties": false,
      "properties": {
        "full_name": {
          "type": "string",
          "pattern": "^[a-z0-9_]+\\.[a-z0-9_]+\\.[a-zA-Z0-9_]+$"
        },
        "catalog": { "type": "string", "minLength": 1 },
        "schema": { "type": "string", "minLength": 1 },
        "table_type": {
          "type": "string",
          "enum": ["MANAGED", "EXTERNAL", "VIEW", "MATERIALIZED_VIEW", "STREAMING_TABLE"]
        },
        "wiki_status": {
          "type": "string",
          "enum": [
            "documented_in_pack",
            "documented_external",
            "in_scope_not_yet_authored",
            "terminal_no_wiki",
            "out_of_scope"
          ]
        },
        "routing_rule": {
          "type": ["integer", "null"],
          "enum": [1, 2, 3, 4, 5, null]
        },
        "cached_wiki_path": {
          "type": ["string", "null"]
        },
        "in_pilot_scope": { "type": "boolean" },
        "topological_layer": { "type": "integer", "minimum": 0 },
        "source_code_available": { "type": "boolean" },
        "column_count": { "type": "integer", "minimum": 0 }
      },
      "allOf": [
        {
          "description": "routing_rule + cached_wiki_path are non-null IFF wiki_status implies the wiki exists.",
          "if": {
            "properties": {
              "wiki_status": {
                "enum": ["documented_in_pack", "documented_external"]
              }
            }
          },
          "then": {
            "properties": {
              "routing_rule": { "type": "integer", "enum": [1, 2, 3, 4, 5] },
              "cached_wiki_path": { "type": "string", "minLength": 1 }
            }
          },
          "else": {
            "properties": {
              "routing_rule": { "type": "null" },
              "cached_wiki_path": { "type": "null" }
            }
          }
        }
      ]
    },
    "edge": {
      "type": "object",
      "required": ["from_node", "to_node", "from_column", "to_column", "event_count_90d", "is_passthrough_only"],
      "additionalProperties": false,
      "properties": {
        "from_node": { "type": "string", "pattern": "^[a-z0-9_]+\\.[a-z0-9_]+\\.[a-zA-Z0-9_]+$" },
        "to_node": { "type": "string", "pattern": "^[a-z0-9_]+\\.[a-z0-9_]+\\.[a-zA-Z0-9_]+$" },
        "from_column": { "type": "string", "minLength": 1 },
        "to_column": { "type": "string", "minLength": 1 },
        "event_count_90d": { "type": "integer", "minimum": 1 },
        "is_passthrough_only": { "type": "boolean" }
      }
    }
  }
}
